# TaskNest Customer Success FTE - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Environment
# ============================================
ENVIRONMENT=development  # development, staging, production
ENABLE_DOCS=true  # Set to false to disable Swagger/ReDoc docs in production

# ============================================
# Database (Neon PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/database
POSTGRES_HOST=your-neon-host.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=tasknest
POSTGRES_USER=your-user
POSTGRES_PASSWORD=your-password

# Database Pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# ============================================
# OpenAI API
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
AGENT_MODEL=gpt-4o  # or gpt-4o-mini for cost savings

# ============================================
# Apache Kafka
# ============================================
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ============================================
# Gmail API (Email Channel)
# ============================================
GMAIL_ENABLED=false
GMAIL_ADDRESS=support@tasknest.com
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=

# ============================================
# Twilio WhatsApp (WhatsApp Channel)
# ============================================
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ============================================
# Web Form (Web Channel)
# ============================================
WEBFORM_ENABLED=true

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,https://tasknest.com

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# Worker Configuration
# ============================================
WORKER_POOL_SIZE=4  # Number of worker processes

# ============================================
# Better Auth Configuration
# ============================================
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-long-here
BETTER_AUTH_URL=http://localhost:3000

# Optional: Social Login Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
